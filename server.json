{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.KrystalView/krystalview",
  "title": "KrystalView Analytics",
  "description": "AI agent access to website analytics, session replay, and anomaly detection.",
  "repository": {
    "url": "https://github.com/KrystalView/krystalview-mcp",
    "source": "github"
  },
  "version": "0.1.4",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "krystalview-mcp",
      "version": "0.1.4",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "KRYSTALVIEW_API_KEY",
          "description": "Your KrystalView API key (generate in console under Settings > API Keys)",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "KRYSTALVIEW_BASE_URL",
          "description": "API base URL (default: https://app.krystalview.com/api)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
